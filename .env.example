DATAINSIGHT_STORAGE_DIR=./storage
DATAINSIGHT_VECTOR_COLLECTION=data_insight_documents
DATAINSIGHT_CHUNK_SIZE=900
DATAINSIGHT_CHUNK_OVERLAP=120

# Retrieval backend: local_agentic_rag or google_agentic_rag.
RETRIEVAL_BACKEND=local_agentic_rag

# Optional LLM synthesis. Keep provider=none for a fully local demo.
DATAINSIGHT_LLM_PROVIDER=none
DATAINSIGHT_LLM_MODEL=gpt-4o-mini
DATAINSIGHT_LLM_BASE_URL=https://api.openai.com/v1
DATAINSIGHT_LLM_API_KEY=
DATAINSIGHT_LLM_TIMEOUT_SECONDS=30

# Optional Google Agentic RAG / Cross Corpus Retrieval adapter.
# Leave these empty for local-only development.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_RAG_CORPUS_IDS=
GOOGLE_APPLICATION_CREDENTIALS=
